# ─── Development (Vite proxy → local API) ───
VITE_API_URL=/api
VITE_SOCKET_URL=
# Backend port for Vite proxy only (not used in production build)
VITE_DEV_API_TARGET=http://127.0.0.1:5000

# ─── Production (npm run build reads .env.production) ───
# Site is HTTPS → API must be HTTPS too, or browser blocks requests (mixed-content).
#
# VITE_API_URL=https://api.safexchange.io/api
# VITE_SOCKET_URL=https://api.safexchange.io
