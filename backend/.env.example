NODE_ENV=development
PORT=5001
# Paste from Atlas → Connect. If password has ! @ # etc., URL-encode them (! → %21).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.lzva1gu.mongodb.net/safex?retryWrites=true&w=majority
# Local MongoDB (brew install mongodb-community && brew services start mongodb-community):
# MONGODB_URI=mongodb://127.0.0.1:27017/safex
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Optional: seed admin + internal liquidity user (npm run seed)
ADMIN_EMAIL=admin@safex.local
ADMIN_PASSWORD=ChangeMeAdmin123!
SYSTEM_LIQUIDITY_EMAIL=liquidity@internal.safex
SYSTEM_LIQUIDITY_PASSWORD=LiquidityInternal123!

# Binance (public endpoints; no key required for klines)
BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws




