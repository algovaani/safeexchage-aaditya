NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/vancrypto
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Optional: seed admin + internal liquidity user (npm run seed)
ADMIN_EMAIL=admin@vencrypto.local
ADMIN_PASSWORD=ChangeMeAdmin123!
SYSTEM_LIQUIDITY_EMAIL=liquidity@internal.vencrypto
SYSTEM_LIQUIDITY_PASSWORD=LiquidityInternal123!

# Binance (public endpoints; no key required for klines)
BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
