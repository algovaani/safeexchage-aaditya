NODE_ENV=development
PORT=5000

# MongoDB connection (MONGODB_URI is used by the app; DB_URL alias optional)
MONGODB_URI=mongodb://127.0.0.1:27017/vancrypto
# DB_URL=mongodb://127.0.0.1:27017/vancrypto

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Frontend origin(s) for CORS — comma-separated, no trailing slashes
CORS_ORIGIN=https://safexchange.io,https://www.safexchange.io
FRONTEND_URL=https://safexchange.io

# Public base URL for KYC/deposit file links
API_BASE_URL=http://localhost:5000

# Crypto deposit — platform receiving address
PLATFORM_USDT_ADDRESS=TXyourTRC20AddressOr0xYourERC20Address
PLATFORM_USDT_NETWORKS=TRC20,ERC20

# Fiat deposit — platform bank details (shown to users)
PLATFORM_BANK_NAME=SafeXchange Pvt Ltd
PLATFORM_BANK_ACCOUNT=123456789012
PLATFORM_BANK_IFSC=SBIN0001234
PLATFORM_BANK_HOLDER=SafeXchange

# Optional: seed admin + internal liquidity user (npm run seed)
ADMIN_EMAIL=admin@safexchange.io
ADMIN_PASSWORD=your-secure-admin-password
SYSTEM_LIQUIDITY_EMAIL=liquidity@internal.safex
SYSTEM_LIQUIDITY_PASSWORD=LiquidityInternal123!

# Binance (public endpoints; no key required for klines)
BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# NinzaSMS — OTP SMS (https://ninzasms.in.net)
NINZASMS_API_URL=https://ninzasms.in.net/auth/send_sms
NINZASMS_API_KEY=your-ninzasms-api-key
NINZASMS_SENDER_ID=your-sender-id
