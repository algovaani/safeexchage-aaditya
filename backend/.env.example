NODE_ENV=development
PORT=5000

# MongoDB connection (MONGODB_URI is used by the app; DB_URL alias optional)
MONGODB_URI=mongodb://127.0.0.1:27017/vancrypto
# DB_URL=mongodb://127.0.0.1:27017/vancrypto

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Frontend origin(s) for CORS — comma-separated, no trailing slashes
# Production (required on server .env):
CORS_ORIGIN=https://safexchange.io,https://www.safexchange.io
FRONTEND_URL=https://www.safexchange.io
# Set to 0 only if not behind a reverse proxy
TRUST_PROXY=1
# OTP rate limits (optional)
# OTP_RATE_LIMIT_PER_MOBILE=5
# OTP_RATE_LIMIT_PER_IP=30

# Public base URL for KYC/deposit file links
API_BASE_URL=http://localhost:5000

# Crypto deposit — platform receiving address
PLATFORM_USDT_ADDRESS=TXyourTRC20AddressOr0xYourERC20Address
PLATFORM_USDT_NETWORKS=TRC20,ERC20

# Fiat deposit — platform bank details (shown to users)
PLATFORM_BANK_NAME=SafeXchange Pvt Ltd
PLATFORM_BANK_ACCOUNT=123456789012
PLATFORM_BANK_IFSC=SBIN0001234
PLATFORM_BANK_HOLDER=SafeXchange

# Optional: seed admin + internal liquidity user (npm run seed)
ADMIN_EMAIL=admin@safexchange.io
ADMIN_PASSWORD=your-secure-admin-password
SYSTEM_LIQUIDITY_EMAIL=liquidity@internal.safex
SYSTEM_LIQUIDITY_PASSWORD=LiquidityInternal123!

# Moralis — BNB/ETH deposit detection primary (https://admin.moralis.io)
MORALIS_API_KEY=your-moralis-api-key
# Optional: webhook signature secret from Moralis Streams dashboard
# MORALIS_WEBHOOK_SECRET=
# Webhook URL: https://api.yourdomain.com/api/deposit/moralis/webhook

# Tatum — BNB/ETH deposit detection fallback when Moralis quota is hit (https://tatum.io)
TATUM_MAINNET_API_KEY=your-tatum-mainnet-api-key
# TATUM_TESTNET_API_KEY=your-tatum-testnet-api-key
# TATUM_API_KEY=alias-for-mainnet-key

# Free public RPC fallback (tx receipt verify only)
BSC_RPC_URL=https://bsc-dataseed1.binance.org,https://bsc-dataseed2.binance.org
ETH_RPC_URL=https://eth.drpc.org,https://1rpc.io/eth,https://ethereum-rpc.publicnode.com
CHAIN_WATCHER_INTERVAL_MS=60000
CHAIN_WATCHER_BLOCK_RANGE=8
CHAIN_WATCHER_SCAN_NATIVE=1
CHAIN_WATCHER_NATIVE_BLOCKS=4

# Market data — Kraken primary (global, real OHLC), CoinGecko fallback
# kraken | coingecko | auto (default: kraken with coingecko fallback)
MARKET_DATA_PROVIDER=kraken
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_PRICE_CACHE_MS=5000
# CoinGecko fallback (works when Kraken pair unavailable)
# Optional demo/pro API key for higher rate limits
# COINGECKO_API_KEY=
COINGECKO_PRICE_CACHE_MS=12000
COINGECKO_STREAM_POLL_MS=3000
COINGECKO_KLINE_POLL_MS=45000

# NinzaSMS — OTP SMS (https://ninzasms.in.net)
NINZASMS_API_URL=https://ninzasms.in.net/auth/send_sms
NINZASMS_API_KEY=your-ninzasms-api-key
NINZASMS_SENDER_ID=your-sender-id
NINZASMS_ROUTE=sms
