NODE_ENV=development
PORT=5000

# MongoDB connection (MONGODB_URI is used by the app; DB_URL alias optional)
MONGODB_URI=mongodb://127.0.0.1:27017/vancrypto
# DB_URL=mongodb://127.0.0.1:27017/vancrypto

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Frontend origin for CORS (Vite dev server)
FRONTEND_URL=http://localhost:5173
# Legacy alias — FRONTEND_URL takes precedence
CORS_ORIGIN=http://localhost:5173

# Public base URL for KYC/deposit file links
API_BASE_URL=http://localhost:5000

# Crypto deposit — platform receiving address
PLATFORM_USDT_ADDRESS=TXyourTRC20AddressOr0xYourERC20Address
PLATFORM_USDT_NETWORKS=TRC20,ERC20

# Optional: seed admin + internal liquidity user (npm run seed)
ADMIN_EMAIL=admin@platform.com
ADMIN_PASSWORD=ChangeMeAdmin123!
SYSTEM_LIQUIDITY_EMAIL=liquidity@internal.safex
SYSTEM_LIQUIDITY_PASSWORD=LiquidityInternal123!

# Binance (public endpoints; no key required for klines)
BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
